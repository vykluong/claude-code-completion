            '--dry-run[Print what would be tagged without creating it]' \
            '(-f --force)'{-f,--force}'[Skip dirty-tree and tag-exists checks]' \
            '(-m --message)'{-m,--message}'[Tag annotation message (use %s for the version)]:message:' \
