# ---- main entry --------------------------------------------------------------

_claude() {
  local curcontext="$curcontext" state line ret=1
  typeset -A opt_args

  # Global options accepted by the bare `claude` invocation (interactive / -p).
  local -a global_options
  global_options=(
    '*--add-dir[Additional directories to allow tool access to]:directory:_directories'
    '--agent[Agent for the current session]:agent:'
    '--agents[JSON object defining custom agents]:json:'
    '--allow-dangerously-skip-permissions[Enable bypassing all permission checks as an option]'
    '*'{--allowedTools,--allowed-tools}'[Comma or space-separated tools to allow]:tool:_claude_tools'
    '--append-system-prompt[Append a system prompt to the default system prompt]:prompt:'
    '--append-system-prompt-file[Append a system prompt read from a file]:file:_files'
    '--bare[Minimal mode: skip hooks, LSP, plugin sync, auto-memory, and CLAUDE.md discovery]'
    '*--betas[Beta headers to include in API requests (API key users only)]:beta:'
    '--brief[Enable SendUserMessage tool for agent-to-user communication]'
    '(--chrome --no-chrome)--chrome[Enable Claude in Chrome integration]'
    '(--chrome --no-chrome)--no-chrome[Disable Claude in Chrome integration]'
    '(-c --continue)'{-c,--continue}'[Continue the most recent conversation in the current directory]'
    '--dangerously-skip-permissions[Bypass all permission checks]'
    '(-d --debug)'{-d,--debug}'[Enable debug mode with optional category filtering]::filter:'
    '--debug-file[Write debug logs to a specific file path]:path:_files'
    '--disable-slash-commands[Disable all skills]'
    '*'{--disallowedTools,--disallowed-tools}'[Comma or space-separated tools to deny]:tool:_claude_tools'
    '--effort[Effort level for the current session]:level:(low medium high xhigh max)'
    '--exclude-dynamic-system-prompt-sections[Move per-machine sections into the first user message]'
    '--fallback-model[Fallback model when the default is overloaded (only with --print)]:model:_claude_models'
    '*--file[File resources to download at startup (file_id:relative_path)]:spec:'
    '--fork-session[On resume, create a new session ID instead of reusing the original]'
    '--from-pr[Resume a session linked to a PR by number or URL, or open the picker]::pr:'
    '--ide[Automatically connect to IDE on startup if exactly one is available]'
    '--include-hook-events[Include all hook lifecycle events in the output stream]'
    '--include-partial-messages[Include partial message chunks as they arrive]'
    '--input-format[Input format (only with --print)]:format:(text stream-json)'
    '--json-schema[JSON Schema for structured output validation]:schema:'
    '--max-budget-usd[Maximum dollar amount to spend on API calls (only with --print)]:amount:'
    '*--mcp-config[Load MCP servers from JSON files or strings]:config:_files'
    '--mcp-debug[DEPRECATED. Use --debug instead. Enable MCP debug mode]'
    '--model[Model for the current session]:model:_claude_models'
    '(-n --name)'{-n,--name}'[Set a display name for this session]:name:'
    '--no-session-persistence[Disable session persistence (only with --print)]'
    '--output-format[Output format (only with --print)]:format:(text json stream-json)'
    '--permission-mode[Permission mode to use for the session]:mode:(acceptEdits auto bypassPermissions default dontAsk plan)'
    '*--plugin-dir[Load a plugin from a directory or .zip for this session]:path:_files'
    '*--plugin-url[Fetch a plugin .zip from a URL for this session]:url:'
    '(-p --print)'{-p,--print}'[Print response and exit (useful for pipes)]'
    '--prompt-suggestions[Enable prompt suggestions]::value:(true false 1 0 yes no on off)'
    '(--remote-control --rc)'{--remote-control,--rc}'[Start an interactive session with Remote Control enabled]::name:'
    '--remote-control-session-name-prefix[Prefix for auto-generated Remote Control session names]:prefix:'
    '--replay-user-messages[Re-emit user messages from stdin back on stdout]'
    '(-r --resume)'{-r,--resume}'[Resume a conversation by session ID, or open the picker]::session:'
    '--session-id[Use a specific session ID (must be a valid UUID)]:uuid:'
    '--setting-sources[Comma-separated setting sources to load (user, project, local)]:sources:'
    '--settings[Path to a settings JSON file or a JSON string]:file or json:_files'
    '--strict-mcp-config[Only use MCP servers from --mcp-config]'
    '--system-prompt[System prompt to use for the session]:prompt:'
    '--system-prompt-file[System prompt to use, read from a file]:file:_files'
    '--tmux[Create a tmux session for the worktree (requires --worktree)]'
    '*--tools[Available tools from the built-in set]:tool:_claude_tools'
    '--verbose[Override verbose mode setting from config]'
    '(-w --worktree)'{-w,--worktree}'[Create a new git worktree for this session]::name:'
    # Documented in the official CLI reference but hidden from `claude --help`
    # (registered with .hideHelp()); all verified present in the 2.1.158 binary.
    '(--bg --background)'{--bg,--background}'[Start the session as a background agent and return immediately]'
    '--exec[Run a shell command as a background job instead of a Claude session (use with --bg)]:command:'
    '--remote[Create a remote web session with a task description, or attach to an existing one]::description:'
    '--teleport[Resume a web session in your local terminal]::session:'
    '--teammate-mode[How agent team teammates display]:mode:(auto in-process tmux)'
    '--max-turns[Limit the number of agentic turns (print mode only)]:turns:'
    '--permission-prompt-tool[MCP tool to handle permission prompts (only with --print)]:tool:'
    '*--channels[MCP servers whose channel notifications to listen for]:server:'
    '--dangerously-load-development-channels[Enable channel servers not on the approved allowlist]:server:'
    '--init[Run Setup hooks with the init matcher before the session (print mode only)]'
    '--init-only[Run Setup and SessionStart hooks, then exit]'
    '--maintenance[Run Setup hooks with the maintenance matcher before the session (print mode only)]'
    '(-h --help)'{-h,--help}'[Display help for command]'
    '(-v --version)'{-v,--version}'[Output the version number]'
  )

  # Options that take an OPTIONAL value (`::` specs) greedily swallow the next
  # word as their value (e.g. `claude --worktree mcp` names the worktree "mcp",
  # it does not run `mcp`). Offering the command list right after such a flag
  # would suggest subcommands the parser can never dispatch, so suppress it
  # there. Typing an option (PREFIX starts with `-`) is unaffected, and once a
  # value has been supplied the command list returns on the next word.
  local cmd_arg='1: :_claude_commands'
  local -a optval_flags
  optval_flags=(
    -d --debug --from-pr --prompt-suggestions --remote-control --rc
    -r --resume -w --worktree --remote --teleport
  )
  if (( CURRENT > 1 )) && [[ $PREFIX != -* ]] \
     && (( ${optval_flags[(I)$words[CURRENT-1]]} )); then
    cmd_arg='1: :'
  fi

  _arguments -C \
    $global_options \
    "$cmd_arg" \
    '*::arg:->args' && ret=0

  if [[ $state == args ]]; then
    case $line[1] in
      agents)               _claude_agents && ret=0 ;;
      auth)                 _claude_auth && ret=0 ;;
      auto-mode)            _claude_auto_mode && ret=0 ;;
      doctor)               _claude_doctor && ret=0 ;;
      install)              _claude_install && ret=0 ;;
      mcp)                  _claude_mcp && ret=0 ;;
      plugin|plugins)       _claude_plugin && ret=0 ;;
      project)              _claude_project && ret=0 ;;
      setup-token)          _claude_setup_token && ret=0 ;;
      ultrareview)          _claude_ultrareview && ret=0 ;;
      update|upgrade)       _claude_update && ret=0 ;;
      remote-control|rc)    _claude_remote_control && ret=0 ;;
      import-conversations) _claude_import_conversations && ret=0 ;;
      attach)               _claude_attach && ret=0 ;;
      daemon)               _claude_daemon && ret=0 ;;
      logs)                 _claude_logs && ret=0 ;;
      respawn)              _claude_respawn && ret=0 ;;
      rm)                   _claude_rm && ret=0 ;;
      stop|kill)            _claude_stop && ret=0 ;;
      *)                    ret=0 ;;  # free-form prompt: nothing to complete
    esac
  fi

  return ret
}

_claude "$@"
