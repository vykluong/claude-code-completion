# ---- auth --------------------------------------------------------------------

_claude_auth() {
  local curcontext="$curcontext" state line ret=1
  _arguments -C \
    '(-h --help)'{-h,--help}'[Display help for command]' \
    '1: :->cmds' \
    '*::arg:->args' && ret=0
  case $state in
    cmds)
      local -a sub
      sub=(
        'login:Sign in to your Anthropic account'
        'logout:Log out from your Anthropic account'
        'status:Show authentication status'
      )
      _describe -t auth-commands 'auth command' sub && ret=0
      ;;
    args)
      case $line[1] in
        login)
          _arguments -s \
            '--claudeai[Use Claude subscription (default)]' \
            '--console[Use Anthropic Console (API usage billing) instead of Claude subscription]' \
            '--email[Pre-populate email address on the login page]:email:' \
            '--sso[Force SSO login flow]' \
            '(-h --help)'{-h,--help}'[Display help for command]' && ret=0
          ;;
        status)
          _arguments -s \
            '--json[Output as JSON (default)]' \
            '--text[Output as human-readable text]' \
            '(-h --help)'{-h,--help}'[Display help for command]' && ret=0
          ;;
        logout)
          _arguments '(-h --help)'{-h,--help}'[Display help for command]' && ret=0
          ;;
      esac
      ;;
  esac
  return ret
}

