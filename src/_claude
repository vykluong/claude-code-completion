}

# Best-effort: configured MCP server names, read from local config without
# invoking the binary (which would run slow health checks). Requires `jq`;
# silently offers nothing if jq is unavailable or no config is found.
_claude_mcp_servers() {
  (( $+commands[jq] )) || return 1
  local -a servers
  local f
  for f in ./.mcp.json "$HOME/.claude.json"; do
    # Regular files only: a FIFO/socket at ./.mcp.json would block jq (and the
    # shell) forever on every TAB. -f is false for non-regular files.
    [[ -f "$f" && -r "$f" ]] || continue
    servers+=( ${(f)"$(jq -r '
        (.mcpServers // {} | keys[]),
        (.projects[]? .mcpServers // {} | keys[])
      ' "$f" 2>/dev/null)"} )
  done
  (( ${#servers} )) || return 1
  local expl
  # Use compadd (not _describe) so a server name containing ':' is offered
  # whole instead of being split into value:description and truncated.
  _wanted mcp-servers expl 'MCP server' compadd -a servers
}

# Local git refs, used to complete `ultrareview` base-branch targets.
_claude_git_refs() {
  local -a refs
  refs=( ${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads refs/remotes 2>/dev/null)"} )
  (( ${#refs} )) || return 1
  _describe -t git-refs 'git ref' refs
}

# ---- top-level command list --------------------------------------------------

_claude_commands() {
  local -a cmds aliases
  cmds=(
    'agents:Manage background agents'
    'auth:Manage authentication'
    'auto-mode:Inspect auto mode classifier configuration'
    'doctor:Check the health of your Claude Code auto-updater'
    'install:Install Claude Code native build'
    'mcp:Configure and manage MCP servers'
    'plugin:Manage Claude Code plugins'
    'project:Manage Claude Code project state'
    'setup-token:Set up a long-lived authentication token'
    'ultrareview:Run a cloud-hosted multi-agent code review'
    'update:Check for updates and install if available'
    # Real, fully-invokable commands that the binary hides from its own
    # `--help`. They are listed unconditionally so `claude <TAB>` shows every
    # command — not just the documented subset. (All verified present in the
    # 2.1.158 binary.)
    'remote-control:Control local sessions from claude.ai/code or the Claude mobile app'
    'import-conversations:Import conversations from an export path'
    'daemon:Inspect/manage the background-session supervisor'
    'attach:Open a background session in this terminal'
    'logs:Print a background session recent output'
    'respawn:Restart a background session so it picks up the current binary'
    'rm:Delete a background session and its worktree'
    'stop:Stop a background session (alias: kill)'
  )
  # Command aliases — also shown unconditionally, in their own group.
  aliases=(
    'plugins:Manage Claude Code plugins (alias of plugin)'
    'upgrade:Check for updates and install (alias of update)'
    'rc:Control local sessions (alias of remote-control)'
    'kill:Stop a background session (alias of stop)'
  )
  _describe -t commands 'claude command' cmds
  _describe -t command-aliases 'command alias' aliases
}

