        local -a mp_aliases
        mp_aliases=( 'rm:Remove a configured marketplace (alias of remove)' )
        _describe -t marketplace-aliases 'marketplace command alias' mp_aliases && ret=0
      fi
      ;;
    args)
      case $line[1] in
