        details)
          _arguments '(-h --help)'{-h,--help}'[Display help for command]' \
            '1:plugin name:' && ret=0
          ;;
        disable)
          _arguments -s \
            '(-a --all)'{-a,--all}'[Disable all enabled plugins]' \
            '(-s --scope)'{-s,--scope}'[Installation scope]:scope:(user project local)' \
            '(-h --help)'{-h,--help}'[Display help for command]' \
            '1:plugin:' && ret=0
