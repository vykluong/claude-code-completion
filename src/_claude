          _arguments -s \
            '--scope[Where to declare the marketplace]:scope:(user project local)' \
            '*--sparse[Limit checkout to specific directories (for monorepos)]:path:_directories' \
            '(-h --help)'{-h,--help}'[Display help for command]' \
            '1:source (URL, path, or GitHub repo):_files' && ret=0
          ;;
        list)
          _arguments -s \
            '--json[Output as JSON]' \
            '(-h --help)'{-h,--help}'[Display help for command]' && ret=0
          ;;
        remove|rm)
          _arguments -s \
            '--scope[Settings scope to remove the declaration from]:scope:(user project local)' \
