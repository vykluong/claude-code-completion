        prune|autoremove)
          _arguments -s \
            '--dry-run[List what would be removed without removing]' \
            '(-s --scope)'{-s,--scope}'[Scope to prune at]:scope:(user project local)' \
            '(-y --yes)'{-y,--yes}'[Skip the confirmation prompt]' \
            '(-h --help)'{-h,--help}'[Display help for command]' && ret=0
          ;;
        tag)
